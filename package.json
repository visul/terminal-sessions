{
  "name": "terminal-sessions",
  "displayName": "Terminal Sessions",
  "description": "Persistent terminal sessions for Cursor/VSCode via tmux — survive editor restart, workspace-scoped. Live Claude Code status in the sidebar: working/tool/waiting state, API-equivalent cost in USD, context-window %, last user/assistant messages, fuzzy search across every past Claude conversation.",
  "version": "0.12.3",
  "publisher": "visul",
  "license": "MIT",
  "icon": "media/extension-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/visul/terminal-sessions.git"
  },
  "bugs": {
    "url": "https://github.com/visul/terminal-sessions/issues"
  },
  "homepage": "https://github.com/visul/terminal-sessions#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "tmux",
    "sessions",
    "persistent",
    "claude",
    "claude-code",
    "cursor",
    "resume"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Terminal Sessions",
      "properties": {
        "terminalSessions.tmuxPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to tmux binary. Leave empty to autodetect from common locations and PATH."
        },
        "terminalSessions.sessionPrefix": {
          "type": "string",
          "default": "ts",
          "description": "Prefix for all tmux session names created by this extension."
        },
        "terminalSessions.autoRestore": {
          "type": "string",
          "enum": [
            "auto",
            "ask",
            "off"
          ],
          "default": "ask",
          "description": "Behavior when opening a workspace that has detached sessions: auto-resume all, ask via toast, or off."
        },
        "terminalSessions.autoRestoreMaxAgeHours": {
          "type": "number",
          "default": 72,
          "description": "Skip auto-restore for sessions untouched longer than this (hours)."
        },
        "terminalSessions.pruneAfterDays": {
          "type": "number",
          "default": 14,
          "description": "Offer to prune sessions untouched longer than this (days). Set to 0 to disable."
        },
        "terminalSessions.enableCostTracker": {
          "type": "boolean",
          "default": false,
          "description": "Reserved. Cost tracking was removed in v0.4.2 (API rate card was misleading for Max/Team plan users). Tokens usage is still available via Claude's own `claude /status` command."
        },
        "terminalSessions.enableLongRunNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Notify when a terminal command takes longer than the threshold."
        },
        "terminalSessions.longRunThresholdSeconds": {
          "type": "number",
          "default": 30,
          "description": "Minimum duration (seconds) for long-run command notifications."
        },
        "terminalSessions.nativeNotifications": {
          "type": "string",
          "enum": [
            "auto",
            "always",
            "never"
          ],
          "default": "auto",
          "description": "macOS Notification Center behavior. auto = native when Cursor unfocused, toast when focused; always = always native; never = only VS Code toast."
        },
        "terminalSessions.notificationSound": {
          "type": "string",
          "enum": [
            "Basso",
            "Blow",
            "Bottle",
            "Frog",
            "Funk",
            "Glass",
            "Hero",
            "Morse",
            "Ping",
            "Pop",
            "Purr",
            "Sosumi",
            "Submarine",
            "Tink"
          ],
          "default": "Glass",
          "description": "Default sound for native notifications (macOS built-in sounds). Errors override with Basso."
        },
        "terminalSessions.notifyOnClaudeStop": {
          "type": "boolean",
          "default": true,
          "description": "Send a notification when Claude Code finishes a response. Requires Claude hook installed."
        },
        "terminalSessions.notifyOnClaudeWaiting": {
          "type": "boolean",
          "default": true,
          "description": "Send a notification when Claude Code blocks waiting for your permission (tool approval, risky command, etc.). Distinct sound from the `done` notification so you can tell them apart at a glance."
        },
        "terminalSessions.waitingAlertStyle": {
          "type": "string",
          "enum": ["banner", "alert"],
          "enumDescriptions": [
            "Banner notification that auto-dismisses after a few seconds (system default).",
            "Persistent modal alert dialog in the macOS foreground with a `Show terminal` button. Blocks until you dismiss — use only if you miss the banners."
          ],
          "default": "banner",
          "description": "How to surface Claude waiting-for-permission events."
        },
        "terminalSessions.notificationSoundWaiting": {
          "type": "string",
          "enum": [
            "Basso", "Blow", "Bottle", "Frog", "Funk", "Glass", "Hero",
            "Morse", "Ping", "Pop", "Purr", "Sosumi", "Submarine", "Tink"
          ],
          "default": "Sosumi",
          "description": "Sound for `Claude needs approval` waiting notifications. Defaults to Sosumi so it is distinct from the `done` sound."
        },
        "terminalSessions.claudeStopMinDurationSeconds": {
          "type": "number",
          "default": 15,
          "description": "Only notify on Claude Stop if session has been running at least N seconds (avoids notif-storm on short turns)."
        },
        "terminalSessions.autoResumeClaude": {
          "type": "boolean",
          "default": false,
          "description": "After recreating sessions post-reboot, auto-run `claude --resume <id>` in the attached terminal. OFF by default because it can accidentally send text into a running Claude process. Safer: let the summary toast hint you the command and run it manually."
        },
        "terminalSessions.contextWarnPct": {
          "type": "number",
          "default": 0.8,
          "minimum": 0,
          "maximum": 1,
          "description": "Show a context-window warning badge (e.g. `87% ctx`) next to the Claude state when the latest turn crossed this percentage of the model's context limit. Set to 1 to disable the badge. Default 0.8 = warn at 80%."
        },
        "terminalSessions.claudeSidebarDetails": {
          "type": "string",
          "enum": ["auto", "always", "off"],
          "enumDescriptions": [
            "Expand Claude details (last message, tool, model, tokens) only while Claude is actively working or needs input.",
            "Always show Claude details as nested rows under every session that has a Claude history.",
            "Never show Claude details as nested rows. Info stays in the tooltip."
          ],
          "default": "auto",
          "description": "Show per-session Claude Code details (last user/assistant message, current tool, model, tokens) as nested rows in the sidebar. Requires the Claude hook to be installed."
        },
        "terminalSessions.showCompletedSubagents": {
          "type": "boolean",
          "default": true,
          "description": "Show subagents that have already finished (Task tool_result received) in the sidebar. On by default so short-running agents don't flicker in and out; flip to false if the tree gets too busy in sessions with many completed agents."
        },
        "terminalSessions.sidebarSortMode": {
          "type": "string",
          "enum": ["custom", "mru", "created", "alphabetical"],
          "enumDescriptions": [
            "User-defined order — drag sessions in the sidebar to rearrange; persisted across restarts.",
            "Most recently focused session first.",
            "Creation order (oldest first) — default.",
            "Alphabetical by session label."
          ],
          "default": "created",
          "description": "How to sort sessions under each workspace in the sidebar. Click the list-ordered icon in the sidebar title bar to switch modes interactively. Dragging a session switches automatically to 'custom'."
        }
      }
    },
    "commands": [
      {
        "command": "terminalSessions.newPersistent",
        "title": "Terminal Sessions: New Persistent Terminal",
        "icon": "$(add)"
      },
      {
        "command": "terminalSessions.newPersistentInFolder",
        "title": "Open in Integrated Terminal - Persistent"
      },
      {
        "command": "terminalSessions.attachTo",
        "title": "Terminal Sessions: Attach to Session..."
      },
      {
        "command": "terminalSessions.kill",
        "title": "Kill Session",
        "icon": "$(trash)"
      },
      {
        "command": "terminalSessions.killAllStale",
        "title": "Terminal Sessions: Kill All Stale Sessions"
      },
      {
        "command": "terminalSessions.killWorkspace",
        "title": "Terminal Sessions: Kill All Sessions for This Workspace"
      },
      {
        "command": "terminalSessions.refreshSidebar",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "terminalSessions.revealSidebar",
        "title": "Terminal Sessions: Reveal Sidebar"
      },
      {
        "command": "terminalSessions.preview",
        "title": "Preview Scrollback",
        "icon": "$(eye)"
      },
      {
        "command": "terminalSessions.rename",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "terminalSessions.resumeAll",
        "title": "Terminal Sessions: Resume All For Workspace"
      },
      {
        "command": "terminalSessions.setAsDefaultProfile",
        "title": "Terminal Sessions: Set as Default Terminal Profile"
      },
      {
        "command": "terminalSessions.openTmuxConfig",
        "title": "Terminal Sessions: Open tmux.conf"
      },
      {
        "command": "terminalSessions.reloadTmuxConfig",
        "title": "Terminal Sessions: Reload tmux config"
      },
      {
        "command": "terminalSessions.setIcon",
        "title": "Change Icon...",
        "icon": "$(symbol-color)"
      },
      {
        "command": "terminalSessions.setColor",
        "title": "Change Color...",
        "icon": "$(paintcan)"
      },
      {
        "command": "terminalSessions.mirror",
        "title": "Open Mirror (attach to same session)",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "terminalSessions.restoreFromIndex",
        "title": "Terminal Sessions: Recreate Sessions from Index (after reboot)"
      },
      {
        "command": "terminalSessions.testNotification",
        "title": "Terminal Sessions: Test Native Notification"
      },
      {
        "command": "terminalSessions.installClaudeHook",
        "title": "Terminal Sessions: Install Claude Code Hook"
      },
      {
        "command": "terminalSessions.uninstallClaudeHook",
        "title": "Terminal Sessions: Uninstall Claude Code Hook"
      },
      {
        "command": "terminalSessions.restart",
        "title": "Restart Session (kill + fresh shell)",
        "icon": "$(debug-restart)"
      },
      {
        "command": "terminalSessions.pickSortMode",
        "title": "Terminal Sessions: Change Sidebar Sort",
        "icon": "$(list-ordered)"
      },
      {
        "command": "terminalSessions.findSession",
        "title": "Terminal Sessions: Find Session by Prompt...",
        "icon": "$(search)"
      },
      {
        "command": "terminalSessions.fixClaudeRendering",
        "title": "Terminal Sessions: Fix Claude Code Rendering in Shell"
      },
      {
        "command": "terminalSessions.toggleAllAlerts",
        "title": "Terminal Sessions: Toggle Claude Waiting Alerts (Global)"
      },
      {
        "command": "terminalSessions.alertsDisable",
        "title": "Disable Claude Waiting Alerts",
        "icon": "$(bell)"
      },
      {
        "command": "terminalSessions.alertsEnable",
        "title": "Enable Claude Waiting Alerts",
        "icon": "$(bell-slash)"
      },
      {
        "command": "terminalSessions.muteSession",
        "title": "Mute Notifications",
        "icon": "$(bell-slash)"
      },
      {
        "command": "terminalSessions.unmuteSession",
        "title": "Unmute Notifications",
        "icon": "$(bell)"
      },
      {
        "command": "terminalSessions.openSubagentTranscript",
        "title": "Open Subagent Transcript",
        "icon": "$(file-code)"
      },
      {
        "command": "terminalSessions.toggleShowCompletedSubagents",
        "title": "Terminal Sessions: Toggle Show Completed Subagents"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "terminalSessions.newPersistentInFolder",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "terminalSessions.findSession",
          "when": "view == terminalSessions.sessions",
          "group": "navigation@0"
        },
        {
          "command": "terminalSessions.pickSortMode",
          "when": "view == terminalSessions.sessions",
          "group": "navigation@1"
        },
        {
          "command": "terminalSessions.newPersistent",
          "when": "view == terminalSessions.sessions",
          "group": "navigation@2"
        },
        {
          "command": "terminalSessions.refreshSidebar",
          "when": "view == terminalSessions.sessions",
          "group": "navigation@3"
        },
        {
          "command": "terminalSessions.alertsDisable",
          "when": "view == terminalSessions.sessions && terminalSessions.alertsEnabled",
          "group": "navigation@4"
        },
        {
          "command": "terminalSessions.alertsEnable",
          "when": "view == terminalSessions.sessions && !terminalSessions.alertsEnabled",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "terminalSessions.preview",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "inline@1"
        },
        {
          "command": "terminalSessions.mirror",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "inline@2"
        },
        {
          "command": "terminalSessions.restart",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "inline@3"
        },
        {
          "command": "terminalSessions.kill",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "inline@4"
        },
        {
          "command": "terminalSessions.restart",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "danger@0"
        },
        {
          "command": "terminalSessions.rename",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "edit@1"
        },
        {
          "command": "terminalSessions.setIcon",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "edit@2"
        },
        {
          "command": "terminalSessions.setColor",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "edit@3"
        },
        {
          "command": "terminalSessions.mirror",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "open@1"
        },
        {
          "command": "terminalSessions.preview",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "open@2"
        },
        {
          "command": "terminalSessions.kill",
          "when": "view == terminalSessions.sessions && viewItem =~ /^session/",
          "group": "danger@1"
        },
        {
          "command": "terminalSessions.muteSession",
          "when": "view == terminalSessions.sessions && viewItem == session",
          "group": "edit@4"
        },
        {
          "command": "terminalSessions.unmuteSession",
          "when": "view == terminalSessions.sessions && viewItem == session.muted",
          "group": "edit@4"
        },
        {
          "command": "terminalSessions.openSubagentTranscript",
          "when": "view == terminalSessions.sessions && viewItem == subagent",
          "group": "inline@1"
        },
        {
          "command": "terminalSessions.openSubagentTranscript",
          "when": "view == terminalSessions.sessions && viewItem == subagent",
          "group": "open@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "terminalSessionsContainer",
          "title": "Terminal Sessions",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "terminalSessionsContainer": [
        {
          "id": "terminalSessions.sessions",
          "name": "Sessions",
          "icon": "media/icon.svg"
        }
      ]
    },
    "terminal": {
      "profiles": [
        {
          "id": "terminalSessions.persistent",
          "title": "Persistent Session",
          "icon": "terminal-bash"
        }
      ]
    },
    "colors": [
      {
        "id": "terminalSessions.workingIcon",
        "description": "Icon color when Claude is actively generating a response.",
        "defaults": { "dark": "#E2C08D", "light": "#B8860B", "highContrast": "#FFE082" }
      },
      {
        "id": "terminalSessions.toolIcon",
        "description": "Icon color when Claude is executing a tool (Bash, Edit, etc.).",
        "defaults": { "dark": "#75BEFF", "light": "#007ACC", "highContrast": "#75BEFF" }
      },
      {
        "id": "terminalSessions.waitingIcon",
        "description": "Icon color when Claude is waiting for user permission / input.",
        "defaults": { "dark": "#FF9E2D", "light": "#D97706", "highContrast": "#FFB74D" }
      },
      {
        "id": "terminalSessions.idleIcon",
        "description": "Icon color when Claude finished responding and is idle.",
        "defaults": { "dark": "#73C991", "light": "#389E0D", "highContrast": "#81C784" }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "npx @vscode/vsce package",
    "install-extension": "code --install-extension terminal-sessions-0.1.0.vsix --force"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}